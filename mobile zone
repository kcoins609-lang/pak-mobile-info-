<!DOCTYPE html>

<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>MobileZone — Wholesale Mobiles</title>
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<style>
  :root {
    --green: #00e676;
    --green-dark: #00c853;
    --bg: #0a0a0a;
    --card: #111111;
    --card2: #161616;
    --border: #222;
    --text: #f0f0f0;
    --muted: #888;
    --accent: #ff6b35;
    --wa: #25D366;
  }
  * { margin: 0; padding: 0; box-sizing: border-box; }
  html { scroll-behavior: smooth; }
  body {
    background: var(--bg);
    color: var(--text);
    font-family: 'Outfit', sans-serif;
    overflow-x: hidden;
  }

/* ── HEADER ── */
header {
position: sticky; top: 0; z-index: 100;
background: rgba(10,10,10,0.92);
backdrop-filter: blur(16px);
border-bottom: 1px solid var(–border);
padding: 14px 20px;
display: flex; align-items: center; justify-content: space-between;
}
.logo {
font-family: ‘Bebas Neue’, sans-serif;
font-size: 28px;
letter-spacing: 2px;
color: var(–green);
text-shadow: 0 0 20px rgba(0,230,118,0.4);
}
.logo span { color: var(–text); }
.badge-ws {
background: linear-gradient(135deg, var(–green), var(–green-dark));
color: #000;
font-size: 10px;
font-weight: 700;
letter-spacing: 1.5px;
padding: 3px 8px;
border-radius: 20px;
text-transform: uppercase;
margin-left: 8px;
vertical-align: middle;
}
.header-right {
display: flex; align-items: center; gap: 12px;
}
.wa-header {
display: flex; align-items: center; gap: 6px;
background: var(–wa);
color: #fff;
font-size: 13px;
font-weight: 600;
padding: 8px 14px;
border-radius: 8px;
text-decoration: none;
transition: transform .2s, box-shadow .2s;
}
.wa-header:hover { transform: scale(1.04); box-shadow: 0 0 16px rgba(37,211,102,0.4); }
.wa-header svg { width: 16px; height: 16px; fill: #fff; }

/* ── HERO ── */
.hero {
padding: 60px 20px 40px;
text-align: center;
position: relative;
overflow: hidden;
}
.hero::before {
content: ‘’;
position: absolute; top: -80px; left: 50%; transform: translateX(-50%);
width: 600px; height: 300px;
background: radial-gradient(ellipse, rgba(0,230,118,0.12) 0%, transparent 70%);
pointer-events: none;
}
.hero-tag {
display: inline-block;
font-size: 11px; font-weight: 600; letter-spacing: 2px;
text-transform: uppercase; color: var(–green);
border: 1px solid rgba(0,230,118,0.3);
padding: 5px 14px; border-radius: 20px;
margin-bottom: 18px;
animation: fadeUp .6s ease both;
}
.hero h1 {
font-family: ‘Bebas Neue’, sans-serif;
font-size: clamp(48px, 12vw, 80px);
line-height: 1;
letter-spacing: 3px;
animation: fadeUp .7s .1s ease both;
}
.hero h1 em { color: var(–green); font-style: normal; }
.hero p {
margin-top: 14px;
color: var(–muted);
font-size: 15px;
max-width: 340px; margin-inline: auto;
animation: fadeUp .7s .2s ease both;
}
.hero-stats {
display: flex; justify-content: center; gap: 28px;
margin-top: 30px;
animation: fadeUp .7s .3s ease both;
}
.stat { text-align: center; }
.stat-val {
font-family: ‘Bebas Neue’, sans-serif;
font-size: 30px; color: var(–green); line-height: 1;
}
.stat-label { font-size: 11px; color: var(–muted); letter-spacing: .5px; }

/* ── TRUST BANNER ── */
.trust-bar {
display: flex; overflow: hidden;
border-top: 1px solid var(–border);
border-bottom: 1px solid var(–border);
margin: 10px 0;
background: var(–card);
}
.trust-track {
display: flex; gap: 48px;
padding: 12px 24px;
white-space: nowrap;
animation: marquee 20s linear infinite;
flex-shrink: 0;
}
.trust-item {
font-size: 12px; font-weight: 600; letter-spacing: 1px;
color: var(–muted); text-transform: uppercase;
display: flex; align-items: center; gap: 8px;
}
.trust-item .dot { width: 6px; height: 6px; background: var(–green); border-radius: 50%; }
@keyframes marquee { from { transform: translateX(0); } to { transform: translateX(-50%); } }

/* ── FILTERS ── */
.filters {
padding: 18px 16px 8px;
display: flex; gap: 8px; flex-wrap: wrap;
animation: fadeUp .7s .4s ease both;
}
.filter-btn {
font-family: ‘Outfit’, sans-serif;
font-size: 12px; font-weight: 600;
padding: 7px 16px;
border-radius: 20px;
border: 1px solid var(–border);
background: transparent; color: var(–muted);
cursor: pointer; transition: all .2s;
letter-spacing: .5px;
}
.filter-btn.active, .filter-btn:hover {
background: var(–green);
color: #000; border-color: var(–green);
}

/* ── SECTION TITLE ── */
.section-head {
padding: 24px 16px 4px;
display: flex; align-items: center; gap: 12px;
}
.section-head h2 {
font-family: ‘Bebas Neue’, sans-serif;
font-size: 28px; letter-spacing: 2px;
}
.section-head .line {
flex: 1; height: 1px; background: var(–border);
}
.section-head .count {
font-size: 12px; color: var(–muted);
}

/* ── GRID ── */
.grid {
display: grid;
grid-template-columns: repeat(2, 1fr);
gap: 12px;
padding: 10px 12px 30px;
}

/* ── CARD ── */
.card {
background: var(–card);
border: 1px solid var(–border);
border-radius: 16px;
overflow: hidden;
position: relative;
transition: transform .2s, border-color .2s;
animation: fadeUp .5s ease both;
}
.card:hover { transform: translateY(-3px); border-color: rgba(0,230,118,0.3); }
.card.new-model::before {
content: ‘NEW’;
position: absolute; top: 10px; left: 10px; z-index: 2;
background: var(–green); color: #000;
font-size: 9px; font-weight: 700; letter-spacing: 1.5px;
padding: 3px 7px; border-radius: 4px;
}
.card.hot::before {
content: ‘HOT 🔥’;
background: var(–accent); color: #fff;
}
.card-img {
width: 100%; aspect-ratio: 1;
display: flex; align-items: center; justify-content: center;
background: var(–card2);
font-size: 64px;
position: relative;
overflow: hidden;
}
.card-img img {
width: 100%; height: 100%;
object-fit: cover;
transition: transform .35s ease;
display: block;
}
.card:hover .card-img img { transform: scale(1.06); }
.card-img .battery-tag {
position: absolute; bottom: 8px; right: 8px;
background: rgba(0,0,0,0.8);
border: 1px solid rgba(0,230,118,0.4);
color: var(–green);
font-size: 10px; font-weight: 600;
padding: 3px 7px; border-radius: 5px;
display: flex; align-items: center; gap: 3px;
}
.card-body { padding: 12px; }
.card-brand {
font-size: 10px; font-weight: 600;
text-transform: uppercase; letter-spacing: 1.5px;
color: var(–muted); margin-bottom: 3px;
}
.card-name {
font-size: 14px; font-weight: 600; line-height: 1.2;
margin-bottom: 6px;
}
.card-specs {
display: flex; flex-wrap: wrap; gap: 4px; margin-bottom: 10px;
}
.spec-chip {
font-size: 10px; font-weight: 500;
background: var(–card2);
border: 1px solid var(–border);
padding: 2px 7px; border-radius: 4px;
color: var(–muted);
}
.price-row {
display: flex; align-items: center; justify-content: space-between;
margin-bottom: 10px;
}
.price-label {
font-size: 11px; color: var(–muted);
}
.price-ws {
font-family: ‘Bebas Neue’, sans-serif;
font-size: 18px; color: var(–green);
letter-spacing: 1px;
}
.price-ws small {
font-family: ‘Outfit’, sans-serif;
font-size: 10px; color: var(–muted);
font-weight: 400; letter-spacing: 0;
display: block; margin-top: -2px;
}

/* ── BUY BUTTON ── */
.btn-buy {
width: 100%;
display: flex; align-items: center; justify-content: center; gap: 6px;
background: var(–wa);
color: #fff;
font-family: ‘Outfit’, sans-serif;
font-size: 13px; font-weight: 700;
padding: 10px;
border-radius: 10px;
border: none; cursor: pointer;
text-decoration: none;
transition: background .2s, transform .15s, box-shadow .2s;
letter-spacing: .3px;
}
.btn-buy:hover {
background: #1ebe5d;
transform: scale(1.02);
box-shadow: 0 6px 20px rgba(37,211,102,0.35);
}
.btn-buy:active { transform: scale(0.97); }
.btn-buy svg { width: 15px; height: 15px; fill: #fff; flex-shrink: 0; }

/* ── MODAL ── */
.modal-overlay {
display: none;
position: fixed; inset: 0; z-index: 200;
background: rgba(0,0,0,0.85);
backdrop-filter: blur(8px);
align-items: flex-end;
justify-content: center;
}
.modal-overlay.show { display: flex; animation: overlayIn .2s ease; }
.modal {
background: var(–card);
border: 1px solid var(–border);
border-radius: 24px 24px 0 0;
width: 100%; max-width: 480px;
padding: 30px 24px 40px;
text-align: center;
animation: slideUp .3s cubic-bezier(.16,1,.3,1);
}
.modal-handle {
width: 40px; height: 4px;
background: var(–border);
border-radius: 2px;
margin: 0 auto 24px;
}
.modal-icon {
width: 70px; height: 70px;
background: rgba(37,211,102,0.1);
border: 2px solid rgba(37,211,102,0.3);
border-radius: 50%;
display: flex; align-items: center; justify-content: center;
margin: 0 auto 16px;
font-size: 32px;
}
.modal h3 {
font-family: ‘Bebas Neue’, sans-serif;
font-size: 26px; letter-spacing: 2px;
margin-bottom: 6px;
}
.modal-product {
font-size: 13px; color: var(–muted); margin-bottom: 18px;
}
.modal-number {
font-family: ‘Bebas Neue’, sans-serif;
font-size: 38px;
color: var(–green);
letter-spacing: 3px;
text-shadow: 0 0 30px rgba(0,230,118,0.3);
margin-bottom: 6px;
}
.modal-hint {
font-size: 12px; color: var(–muted); margin-bottom: 24px;
}
.modal-note {
font-size: 12px; color: var(–muted);
background: var(–card2); border: 1px solid var(–border);
padding: 10px 14px; border-radius: 10px;
margin-bottom: 20px; line-height: 1.5;
}
.modal-note strong { color: var(–green); }
.btn-wa-open {
display: flex; align-items: center; justify-content: center; gap: 8px;
width: 100%;
background: var(–wa); color: #fff;
font-family: ‘Outfit’, sans-serif;
font-size: 15px; font-weight: 700;
padding: 14px; border-radius: 12px;
border: none; cursor: pointer;
text-decoration: none;
margin-bottom: 10px;
transition: background .2s, transform .15s;
}
.btn-wa-open:hover { background: #1ebe5d; transform: scale(1.02); }
.btn-wa-open svg { width: 20px; height: 20px; fill: #fff; }
.btn-close-modal {
background: transparent; border: 1px solid var(–border);
color: var(–muted); font-family: ‘Outfit’, sans-serif;
font-size: 13px; font-weight: 500;
padding: 10px; width: 100%; border-radius: 10px;
cursor: pointer; transition: border-color .2s, color .2s;
}
.btn-close-modal:hover { border-color: var(–text); color: var(–text); }

/* ── FOOTER ── */
footer {
padding: 30px 20px;
text-align: center;
border-top: 1px solid var(–border);
color: var(–muted); font-size: 12px; line-height: 1.8;
}
footer .f-logo {
font-family: ‘Bebas Neue’, sans-serif;
font-size: 22px; color: var(–green);
letter-spacing: 2px; display: block; margin-bottom: 6px;
}

/* ── KEYFRAMES ── */
@keyframes fadeUp {
from { opacity: 0; transform: translateY(20px); }
to   { opacity: 1; transform: translateY(0); }
}
@keyframes overlayIn { from { opacity: 0; } to { opacity: 1; } }
@keyframes slideUp {
from { transform: translateY(100%); }
to   { transform: translateY(0); }
}

/* stagger cards */
.card:nth-child(1) { animation-delay: .05s; }
.card:nth-child(2) { animation-delay: .10s; }
.card:nth-child(3) { animation-delay: .15s; }
.card:nth-child(4) { animation-delay: .20s; }
.card:nth-child(5) { animation-delay: .25s; }
.card:nth-child(6) { animation-delay: .30s; }
.card:nth-child(7) { animation-delay: .35s; }
.card:nth-child(8) { animation-delay: .40s; }
</style>

</head>
